{
  "name": "minecraftServerManager",
  "requirements": [
    {
      "key": "DATABASE_URL",
      "type": "database",
      "dbType": "postgres",
      "description": "Prisma PostgreSQL Connection URL"
    },
    {
      "key": "PORT",
      "type": "credential",
      "description": "Port the Next.js server listens on"
    },
    {
      "key": "JWT_SECRET",
      "type": "credential",
      "description": "Secret key for signing JWT cookies (min 32 chars)"
    },
    {
      "key": "LOGIN_USERNAME",
      "type": "credential",
      "description": "Benutzername für den Admin-Login"
    },
    {
      "key": "LOGIN_PASSWORD",
      "type": "credential",
      "description": "Passwort für den Admin-Login"
    },
    {
      "key": "MINECRAFT_SERVERS_DIR",
      "type": "credential",
      "description": "Directory where Minecraft Server files will be stored (default: ./servers)"
    }
  ]
}
